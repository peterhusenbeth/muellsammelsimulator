#:import colors kivy.utils.get_color_from_hex

<ShopArtikel>:
    canvas.before:
        Color:
            rgba: self.hintergrund_farbe if hasattr(self, 'hintergrund_farbe') else colors('#FFCC80')
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]
        Color:
            rgba: colors('#7B1FA2')
        Line:
            rectangle: (self.x, self.y, self.width, self.height)
            width: 3

<EinkaufsladenBildschirm>:
    FloatLayout:
        id: shop_root
        canvas.before:
            Rectangle:
                source: 'assets/einkaufsladen_hintergrund.jpg'
                size: self.size
                pos: self.pos

        # Menü-Button oben links
        Button:
            text: 'Menü'
            font_size: 32
            bold: True
            size_hint: None, None
            size: 200, 70
            pos_hint: {'x': 0.02, 'top': 0.95}
            background_normal: ''
            background_down: ''
            background_color: colors('#D1C4E9')
            color: colors('#4A148C')
            on_press: root.zurueck_zum_menue_geplant(self)
            canvas.after:
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 2

        # Titel oben mittig
        Label:
            text: 'Einkaufsladen'
            font_size: 90
            bold: True
            color: colors('#4A148C')
            size_hint: None, None
            size: 800, 100
            pos_hint: {'center_x': 0.5, 'top': 0.95}
            canvas.before:
                Color:
                    rgba: colors('#D1C4E9')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15,]
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 3

        # Guthaben-Anzeige oben rechts
        Label:
            id: guthaben_label
            text: 'Guthaben: 0 Punkte'
            font_size: 40
            bold: True
            color: colors('#4A148C')
            size_hint: None, None
            size: 450, 70
            pos_hint: {'right': 0.98, 'top': 0.95}
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            canvas.before:
                Color:
                    rgba: colors('#D1C4E9')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15,]
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 3

        # Bereich: Neue Levels
        Label:
            text: 'Neue Levels'
            font_size: 36
            bold: True
            color: colors('#4A148C')
            size_hint: None, None
            size: 300, 50
            pos_hint: {'center_x': 0.5, 'top': 0.82}
            canvas.before:
                Color:
                    rgba: colors('#D1C4E9')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 2

        BoxLayout:
            id: level_reihe
            orientation: 'horizontal'
            size_hint: None, None
            size: 1800, 140
            pos_hint: {'center_x': 0.5, 'top': 0.75}
            spacing: 20
            padding: 10

        # Bereich: Müll-Gegenstände (unten links)
        Label:
            text: 'Müll-Gegenstände'
            font_size: 36
            bold: True
            color: colors('#4A148C')
            size_hint: None, None
            size: 400, 50
            pos_hint: {'center_x': 0.25, 'top': 0.50}
            canvas.before:
                Color:
                    rgba: colors('#D1C4E9')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 2

        BoxLayout:
            id: muell_reihe
            orientation: 'horizontal'
            size_hint: None, None
            size: 770, 110
            pos_hint: {'x': 0.05, 'top': 0.42}
            spacing: 15
            padding: 10

        # Bereich: Natur-Gegenstände (unten rechts)
        Label:
            text: 'Natur-Gegenstände'
            font_size: 36
            bold: True
            color: colors('#4A148C')
            size_hint: None, None
            size: 400, 50
            pos_hint: {'center_x': 0.75, 'top': 0.50}
            canvas.before:
                Color:
                    rgba: colors('#D1C4E9')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]
                Color:
                    rgba: colors('#7B1FA2')
                Line:
                    rectangle: (self.x, self.y, self.width, self.height)
                    width: 2

        BoxLayout:
            id: natur_reihe
            orientation: 'horizontal'
            size_hint: None, None
            size: 770, 110
            pos_hint: {'right': 0.95, 'top': 0.42}
            spacing: 15
            padding: 10
